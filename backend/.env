# Environment
ENVIRONMENT=development
DEBUG=False

# MongoDB Settings
MONGO_URI=mongodb://localhost:27017
MONGODB_NAME=chatsphere
MONGO_POOL_SIZE=10
MONGO_MAX_IDLE_TIME_MS=45000

# JWT Settings
JWT_SECRET_KEY=4da4c141bbdabaa2aa85170dd42ebc707104bf2742021195849dec455570c0cde71f1787aecc519b50fea6d3b442ee3be9a63f3984be3805f230c5db205934ff
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_TIME_DELTA=3600

# Socket.IO Settings
SOCKET_IO_PORT=3000
SOCKET_IO_PING_TIMEOUT=60
SOCKET_IO_PING_INTERVAL=25

# CORS Settings
CORS_ORIGIN=http://localhost:5173

# Ollama Settings (for local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=120

# OpenAI Settings (for GPT-4 features)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_API_TIMEOUT=30

# Redis Settings (for caching & presence)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_EXPIRY=3600

# Rate Limiting Settings
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# API Settings
REQUEST_TIMEOUT=30
MAX_REQUEST_SIZE=10485760

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security Settings
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL=True
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_DIGITS=True

# Session Settings
SESSION_TIMEOUT_MINUTES=30

# File Upload Settings
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_EXTENSIONS=jpg,jpeg,png,gif,pdf,txt